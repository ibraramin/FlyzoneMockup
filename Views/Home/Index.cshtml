@section Scripts {
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        // Initialize the Leaflet map
        // Centered between UAE and South Asia
        const map = L.map('map-container', {
            zoomControl: false // Hides the default +/- buttons for a cleaner hero section
        }).setView([24.0, 65.0], 4.5);

        // Add CartoDB Positron (Light) tile layer - 100% Free, no tokens needed
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
            subdomains: 'abcd',
            maxZoom: 20
        }).addTo(map);

        // Note: Leaflet uses [Latitude, Longitude] instead of Mapbox's [Lng, Lat]
        const locations = [
            { name: 'Dubai', latLng: [25.2048, 55.2708], type: 'red' },
            { name: 'Ajman', latLng: [25.4052, 55.4481], type: 'red' },
            { name: 'Saudi Arabia', latLng: [23.8859, 45.0792], type: 'red' },
            { name: 'Qatar', latLng: [25.2854, 51.5310], type: 'red' },
            { name: 'India', latLng: [20.5937, 78.9629], type: 'red' },
            { name: 'Bangladesh', latLng: [23.8103, 90.4125], type: 'red' }
        ];

        // Create HTML markers and add them to the map
        locations.forEach(loc => {
            // Leaflet allows us to inject raw HTML via divIcon
            const customIcon = L.divIcon({
                className: 'custom-leaflet-icon', // Wrapper class
                html: `<div class="map-dot dot-${loc.type}"><span class="map-label">${loc.name}</span></div>`,
                iconSize: [14, 14],
                iconAnchor: [7, 7] // Centers the dot perfectly on the coordinate
            });

            L.marker(loc.latLng, { icon: customIcon }).addTo(map);
        });

    </script>
}