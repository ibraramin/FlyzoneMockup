@{
    ViewData["Title"] = "Dashboard";
    Layout = null; 
    var userName = TempData["Name"] as string ?? "Valued Client";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flyzone Tourism</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/flyzone-dashboard.css" asp-append-version="true" />
</head>
<body>

    <!-- Mobile Overlay -->
    <div class="overlay" id="sidebarOverlay"></div>

    <div id="wrapper">
        
        <!-- 1. Sidebar Navigation -->
        <nav id="sidebar">
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Home")" class="brand-logo d-flex align-items-center justify-content-center justify-content-lg-start">
                    <i class="fa-solid fa-feather-pointed me-2" style="color: var(--fz-green);"></i>
                    <span class="brand-text">FLY<span>ZONE</span></span>
                </a>
            </div>

            <ul class="list-unstyled components mb-0">
                <li class="active">
                    <a href="#" title="Dashboard"><i class="fa-solid fa-border-all"></i> <span class="nav-text">Dashboard</span></a>
                </li>
                <li>
                    <a href="#" title="Start New Application"><i class="fa-solid fa-file-signature"></i> <span class="nav-text">New Application</span></a>
                </li>
                <li>
                    <a href="#" title="My Documents"><i class="fa-solid fa-folder-closed"></i> <span class="nav-text">My Documents</span></a>
                </li>
                <li>
                    <a href="#" title="Track Status"><i class="fa-solid fa-satellite-dish"></i> <span class="nav-text">Track Status</span></a>
                </li>
                <li>
                    <a href="#" title="Schedule Lookup"><i class="fa-regular fa-calendar-check"></i> <span class="nav-text">Schedule Lookup</span></a>
                </li>
                <li>
                    <a href="#" title="Support & Contact"><i class="fa-solid fa-headset"></i> <span class="nav-text">Support & Contact</span></a>
                </li>
            </ul>

            <div class="sidebar-footer mt-auto">
                <!-- Log Out -->
                <a href="@Url.Action("Index", "Home")" class="btn btn-danger w-100 d-flex align-items-center justify-content-center" title="Log Out">
                    <i class="fa-solid fa-right-from-bracket me-2"></i> <span>Log Out</span>
                </a>
            </div>
        </nav>

        <!-- Main Content Area -->
        <div id="content">
            
            <!-- 2. Top Navbar -->
            <nav class="navbar top-navbar mb-4">
                <div class="container-fluid">
                    <!-- Desktop Sidebar Toggle -->
                    <button type="button" id="sidebarCollapseDesktop" class="btn btn-link text-dark p-0 me-3 d-none d-lg-block text-decoration-none">
                        <i class="fa-solid fa-bars-staggered fs-5"></i>
                    </button>

                    <!-- Mobile Hamburger -->
                    <button type="button" id="sidebarCollapseMobile" class="btn btn-dark d-lg-none me-3">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    
                    <h5 class="mb-0 fw-bold d-none d-sm-block text-dark">
                        Welcome back, @userName!
                    </h5>

                    <div class="d-flex align-items-center ms-auto gap-3 gap-md-4">
                        
                        <!-- Language Toggle (Moved to Top Navbar) -->
                        <div class="dropdown d-none d-sm-block">
                            <button class="btn btn-light bg-transparent border-0 fw-semibold dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                                <i class="fa-solid fa-globe me-2 text-secondary"></i> EN
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item active" href="#">English</a></li>
                                <li><a class="dropdown-item" href="#">العربية</a></li>
                                <li><a class="dropdown-item" href="#">বাংলা</a></li>
                            </ul>
                        </div>

                        <!-- Quick Link: WhatsApp -->
                        <a href="https://wa.me/971543149939" target="_blank" class="btn btn-sm btn-success rounded-pill px-3 d-none d-md-block fw-semibold shadow-sm">
                            <i class="fa-brands fa-whatsapp me-1"></i> WhatsApp Support
                        </a>
                        
                        <!-- Quick Action: Notifications -->
                        <div class="position-relative" style="cursor: pointer;">
                            <i class="fa-regular fa-bell fs-5 text-secondary"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </div>
                        
                        <!-- User Profile -->
                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                                <img src="https://ui-avatars.com/api/?name=@userName&background=1A1A1A&color=fff" alt="User Avatar" width="38" height="38" class="rounded-circle border border-2 border-white shadow-sm">
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                <li><a class="dropdown-item" href="#">Profile Settings</a></li>
                                <li><a class="dropdown-item d-sm-none" href="#"><i class="fa-solid fa-globe me-2"></i> Change Language</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Index", "Home")"><i class="fa-solid fa-right-from-bracket me-2"></i>Log Out</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid px-4 pb-4">
                
                <!-- 3. Dashboard Overview -->

                <!-- Top Row: Quick Stats -->
                <div class="row g-4 mb-4">
                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">Total Applications</p>
                                    <h3 class="mb-0 fw-bold">5</h3>
                                </div>
                                <div class="bg-light p-3 rounded-circle text-primary">
                                    <i class="fa-solid fa-file-lines fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">In Progress</p>
                                    <h3 class="mb-0 fw-bold">2</h3>
                                </div>
                                <div class="bg-light p-3 rounded-circle text-warning">
                                    <i class="fa-solid fa-spinner fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6 col-xl-3">
                        <!-- Highlighted Card -->
                        <div class="card dash-card p-3 card-action-required">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-danger small mb-1 fw-bold">Action Required</p>
                                    <h3 class="mb-0 fw-bold text-danger">1</h3>
                                </div>
                                <div class="bg-danger-subtle p-3 rounded-circle text-danger">
                                    <i class="fa-solid fa-circle-exclamation fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">Completed</p>
                                    <h3 class="mb-0 fw-bold">2</h3>
                                </div>
                                <div class="bg-success-subtle p-3 rounded-circle" style="color: var(--fz-green);">
                                    <i class="fa-solid fa-check-double fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Middle Row: Status Tracking Widget -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card dash-card p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="fw-bold mb-0">Current Application Status</h5>
                                <span class="badge bg-dark px-3 py-2">Golden Visa Application</span>
                            </div>
                            
                            <!-- Visual Progress Bar -->
                            <div class="tracker-wrapper">
                                <div class="tracker-line"></div>
                                <div class="tracker-line-progress"></div>
                                
                                <div class="step-container">
                                    <div class="step-item completed">
                                        <div class="step-circle"><i class="fa-solid fa-check"></i></div>
                                        <div class="step-label">Submitted</div>
                                    </div>
                                    <div class="step-item active">
                                        <div class="step-circle"><i class="fa-solid fa-file-circle-check"></i></div>
                                        <div class="step-label">Under Review</div>
                                    </div>
                                    <div class="step-item">
                                        <div class="step-circle"><i class="fa-solid fa-credit-card"></i></div>
                                        <div class="step-label">Waiting Payment</div>
                                    </div>
                                    <div class="step-item">
                                        <div class="step-circle"><i class="fa-solid fa-flag-checkered"></i></div>
                                        <div class="step-label">Completed</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bottom Row: Split Content -->
                <div class="row g-4">
                    <!-- Left: Recent Activity -->
                    <div class="col-lg-8">
                        <div class="card dash-card h-100">
                            <div class="card-header bg-white border-bottom p-4">
                                <h6 class="fw-bold mb-0">Recent Activity</h6>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-borderless table-hover align-middle mb-0">
                                        <thead class="bg-light text-muted small">
                                            <tr>
                                                <th class="ps-4 py-3 fw-semibold">Application Type</th>
                                                <th class="py-3 fw-semibold">Date Submitted</th>
                                                <th class="pe-4 py-3 fw-semibold">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="border-bottom">
                                                <td class="ps-4 py-3 fw-semibold">Driving License Renewal</td>
                                                <td class="py-3 text-muted">May 01, 2026</td>
                                                <td class="pe-4 py-3"><span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Approved</span></td>
                                            </tr>
                                            <tr class="border-bottom bg-danger-subtle bg-opacity-10">
                                                <td class="ps-4 py-3 fw-semibold">New Labour Contract</td>
                                                <td class="py-3 text-muted">Apr 28, 2026</td>
                                                <td class="pe-4 py-3"><span class="badge bg-danger rounded-pill shadow-sm">Requires Action</span></td>
                                            </tr>
                                            <tr class="border-bottom">
                                                <td class="ps-4 py-3 fw-semibold">Vehicle Registration</td>
                                                <td class="py-3 text-muted">Apr 20, 2026</td>
                                                <td class="pe-4 py-3"><span class="badge bg-warning-subtle text-dark border border-warning-subtle rounded-pill">Pending</span></td>
                                            </tr>
                                            <tr>
                                                <td class="ps-4 py-3 fw-semibold">Visit Visa (Dubai)</td>
                                                <td class="py-3 text-muted">Mar 15, 2026</td>
                                                <td class="pe-4 py-3"><span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Approved</span></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Action Center -->
                    <div class="col-lg-4">
                        <div class="card dash-card h-100">
                            <div class="card-header bg-white border-bottom p-4">
                                <h6 class="fw-bold mb-0">Action Center</h6>
                            </div>
                            <div class="card-body d-flex flex-column gap-3 p-4">
                                
                                <button class="btn btn-outline-danger w-100 text-start py-3 px-4 d-flex align-items-center rounded-3">
                                    <i class="fa-solid fa-cloud-arrow-up fs-4 me-3"></i>
                                    <div>
                                        <h6 class="mb-0 fw-bold">Upload Missing Document</h6>
                                        <small class="text-muted">Identity proof required</small>
                                    </div>
                                    <i class="fa-solid fa-chevron-right ms-auto"></i>
                                </button>

                                <button class="btn btn-outline-dark w-100 text-start py-3 px-4 d-flex align-items-center rounded-3">
                                    <i class="fa-solid fa-car-burst fs-4 text-warning me-3"></i>
                                    <div>
                                        <h6 class="mb-0 fw-bold">Check Traffic Fines</h6>
                                        <small class="text-muted">Quick inquiry</small>
                                    </div>
                                    <i class="fa-solid fa-chevron-right ms-auto"></i>
                                </button>
                                
                                <div class="mt-auto pt-3 border-top text-center">
                                    <small class="text-muted d-block mb-2">Need immediate assistance?</small>
                                    <a href="#" class="btn btn-dark w-100">Contact Support</a>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Bootstrap JS bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Sidebar Toggle Script -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const sidebar = document.getElementById('sidebar');
            
            // Desktop Collapse Logic
            const desktopToggleBtn = document.getElementById('sidebarCollapseDesktop');
            desktopToggleBtn.addEventListener('click', function() {
                sidebar.classList.toggle('collapsed');
            });

            // Mobile Off-Canvas Logic
            const overlay = document.getElementById('sidebarOverlay');
            const mobileToggleBtn = document.getElementById('sidebarCollapseMobile');

            function toggleMobileSidebar() {
                sidebar.classList.toggle('active');
                overlay.classList.toggle('active');
            }

            mobileToggleBtn.addEventListener('click', toggleMobileSidebar);
            overlay.addEventListener('click', toggleMobileSidebar); // Clicking outside closes it
        });
    </script>
</body>
</html>