@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
    var userName = Model?.FirstName ?? "Valued Client";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Flyzone Tourism</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/flyzone-dashboard.css" asp-append-version="true" />
</head>
<body>

    <div class="overlay" id="sidebarOverlay"></div>

    <div id="wrapper">
        
        <!-- Sidebar Navigation -->
        <nav id="sidebar">
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Home")" class="brand-logo d-flex align-items-center justify-content-center justify-content-lg-start">
                    <i class="fa-solid fa-feather-pointed me-2" style="color: var(--fz-green);"></i>
                    <span class="brand-text">FLY<span>ZONE</span></span>
                </a>
            </div>

            <ul class="list-unstyled components mb-0">
                <li class="active">
                    <a href="#" title="Dashboard"><i class="fa-solid fa-border-all"></i> <span class="nav-text">Dashboard</span></a>
                </li>
                <li>
                    <a href="@Url.Action("GoldenVisa", "Services")" title="Golden Visa Application"><i class="fa-solid fa-passport"></i> <span class="nav-text">Golden Visa</span></a>
                </li>
                <li>
                    <a href="@Url.Action("DrivingLicense", "Services")" title="Driving License Renewal"><i class="fa-solid fa-car"></i> <span class="nav-text">Driving License</span></a>
                </li>
                <li>
                    <a href="#" title="My Documents"><i class="fa-solid fa-folder-closed"></i> <span class="nav-text">My Documents</span></a>
                </li>
                <li>
                    <a href="#" title="Track Status"><i class="fa-solid fa-satellite-dish"></i> <span class="nav-text">Track Status</span></a>
                </li>
                <li>
                    <a href="#" title="Schedule Lookup"><i class="fa-regular fa-calendar-check"></i> <span class="nav-text">Schedule Lookup</span></a>
                </li>
                <li>
                    <a href="#" title="Support & Contact"><i class="fa-solid fa-headset"></i> <span class="nav-text">Support & Contact</span></a>
                </li>
            </ul>

            <div class="sidebar-footer mt-auto">
                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                    <button type="submit" class="btn btn-danger w-100 d-flex align-items-center justify-content-center" title="Log Out">
                        <i class="fa-solid fa-right-from-bracket me-2"></i> <span>Log Out</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content Area -->
        <div id="content">
            
            <!-- Top Navbar -->
            <nav class="navbar top-navbar mb-4">
                <div class="container-fluid">
                    <!-- Desktop Sidebar Toggle -->
                    <button type="button" id="sidebarCollapseDesktop" class="btn btn-link text-dark p-0 me-3 d-none d-lg-block text-decoration-none">
                        <i class="fa-solid fa-bars-staggered fs-5"></i>
                    </button>

                    <!-- Mobile Hamburger -->
                    <button type="button" id="sidebarCollapseMobile" class="btn btn-dark d-lg-none me-3">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    
                    <h5 class="mb-0 fw-bold d-none d-sm-block text-dark">
                        Welcome back, @userName!
                    </h5>

                    <div class="d-flex align-items-center ms-auto gap-3 gap-md-4">
                        
                        <!-- Language Toggle -->
                        <div class="dropdown d-none d-sm-block">
                            <button class="btn btn-light bg-transparent border-0 fw-semibold dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                                <i class="fa-solid fa-globe me-2 text-secondary"></i> EN
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item active" href="#">English</a></li>
                                <li><a class="dropdown-item" href="#">العربية</a></li>
                                <li><a class="dropdown-item" href="#">বাংলা</a></li>
                            </ul>
                        </div>

                        <!-- Quick Link: WhatsApp -->
                        <a href="https://wa.me/971543149939" target="_blank" class="btn btn-sm btn-success rounded-pill px-3 d-none d-md-block fw-semibold shadow-sm">
                            <i class="fa-brands fa-whatsapp me-1"></i> WhatsApp Support
                        </a>
                        
                        <!-- Quick Action: Notifications -->
                        <div class="position-relative" style="cursor: pointer;">
                            <i class="fa-regular fa-bell fs-5 text-secondary"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                <span class="visually-hidden">New alerts</span>
                            </span>
                        </div>
                        
                        <!-- User Profile -->
                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">
                                <img src="https://ui-avatars.com/api/?name=@userName&background=1A1A1A&color=fff" alt="User Avatar" width="38" height="38" class="rounded-circle border border-2 border-white shadow-sm">
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                <li><a class="dropdown-item" href="#">Profile Settings</a></li>
                                <li><a class="dropdown-item d-sm-none" href="#"><i class="fa-solid fa-globe me-2"></i> Change Language</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Index", "Home")"><i class="fa-solid fa-right-from-bracket me-2"></i>Log Out</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid px-4 pb-4">
                
                <!-- Top Row: Quick Stats -->
                <div class="row g-4 mb-4">
                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">Total Applications</p>
                                    <h3 class="mb-0 fw-bold">@Model.TotalApplications</h3>
                                </div>
                                <div class="bg-light p-3 rounded-circle text-primary">
                                    <i class="fa-solid fa-file-lines fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">In Progress</p>
                                    <h3 class="mb-0 fw-bold">@Model.InProgress</h3>
                                </div>
                                <div class="bg-light p-3 rounded-circle text-warning">
                                    <i class="fa-solid fa-spinner fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3 @(Model.ActionRequired > 0 ? "card-action-required" : "")">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">Action Required</p>
                                    <h3 class="mb-0 fw-bold">@Model.ActionRequired</h3>
                                </div>
                                <div class="bg-light p-3 rounded-circle text-danger">
                                    <i class="fa-solid fa-circle-exclamation fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6 col-xl-3">
                        <div class="card dash-card p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="text-muted small mb-1 fw-semibold">Completed</p>
                                    <h3 class="mb-0 fw-bold">@Model.Completed</h3>
                                </div>
                                <div class="bg-success-subtle p-3 rounded-circle" style="color: var(--fz-green);">
                                    <i class="fa-solid fa-check-double fs-4"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Middle Row: Status Tracking Widget -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="card dash-card p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="fw-bold mb-0">Current Application Status</h5>
                                @if (Model.CurrentActiveApplication != null)
                                {
                                    <span class="badge bg-dark px-3 py-2">@Model.CurrentActiveApplication.ServiceName</span>
                                }
                            </div>
                            
                            @if (Model.CurrentActiveApplication != null)
                            {
                                <div class="tracker-wrapper">
                                    <div class="tracker-line"></div>
                                    @{
                                        var status = Model.CurrentActiveApplication.Status;
                                        var submittedClass = status >= ApplicationStatus.Submitted ? "completed" : "";
                                        var reviewClass = status >= ApplicationStatus.UnderReview ? (status == ApplicationStatus.Submitted ? "active" : "completed") : "";
                                        var paymentClass = status >= ApplicationStatus.WaitingPayment ? (status == ApplicationStatus.UnderReview ? "active" : "completed") : "";
                                        var completedClass = status >= ApplicationStatus.Completed ? (status == ApplicationStatus.WaitingPayment ? "active" : "completed") : "";
                                    }
                                    <div class="tracker-line-progress" style="width: @(status == ApplicationStatus.Submitted ? "5%" : status == ApplicationStatus.UnderReview ? "35%" : status == ApplicationStatus.WaitingPayment ? "65%" : status == ApplicationStatus.Completed || status == ApplicationStatus.ActionRequired ? "100%" : "0%")"></div>
                                    
                                    <div class="step-container">
                                        <div class="step-item @submittedClass">
                                            <div class="step-circle"><i class="fa-solid fa-check"></i></div>
                                            <div class="step-label">Submitted</div>
                                        </div>
                                        <div class="step-item @reviewClass">
                                            <div class="step-circle"><i class="fa-solid fa-file-circle-check"></i></div>
                                            <div class="step-label">Under Review</div>
                                        </div>
                                        <div class="step-item @paymentClass">
                                            <div class="step-circle"><i class="fa-solid fa-credit-card"></i></div>
                                            <div class="step-label">Waiting Payment</div>
                                        </div>
                                        <div class="step-item @completedClass">
                                            <div class="step-circle"><i class="fa-solid fa-flag-checkered"></i></div>
                                            <div class="step-label">Completed</div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="fa-solid fa-folder-open text-muted fs-1 mb-3"></i>
                                    <p class="text-muted mb-3">No active applications</p>
                                    <div class="d-flex justify-content-center gap-3">
                                        <a href="@Url.Action("GoldenVisa", "Services")" class="btn btn-outline-primary">
                                            <i class="fa-solid fa-passport me-2"></i> Apply for Golden Visa
                                        </a>
                                        <a href="@Url.Action("DrivingLicense", "Services")" class="btn btn-outline-primary">
                                            <i class="fa-solid fa-car me-2"></i> Driving License
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Bottom Row: Split Content -->
                <div class="row g-4">
                    <!-- Left: Recent Activity -->
                    <div class="col-lg-8">
                        <div class="card dash-card h-100">
                            <div class="card-header bg-white border-bottom p-4">
                                <h6 class="fw-bold mb-0">Recent Activity</h6>
                            </div>
                            <div class="card-body p-0">
                                @if (Model.RecentActivity.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-borderless table-hover align-middle mb-0">
                                            <thead class="bg-light text-muted small">
                                                <tr>
                                                    <th class="ps-4 py-3 fw-semibold">Application Type</th>
                                                    <th class="py-3 fw-semibold">Date Submitted</th>
                                                    <th class="pe-4 py-3 fw-semibold">Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.RecentActivity)
                                                {
                                                    <tr class="border-bottom">
                                                        <td class="ps-4 py-3 fw-semibold">@item.ApplicationType</td>
                                                        <td class="py-3 text-muted">@item.DateSubmitted.ToString("MMM dd, yyyy")</td>
                                                        <td class="pe-4 py-3">
                                                            @{
                                                                var badgeClass = item.Status switch
                                                                {
                                                                    "Submitted" => "bg-info",
                                                                    "UnderReview" => "bg-warning",
                                                                    "ActionRequired" => "bg-danger",
                                                                    "WaitingPayment" => "bg-primary",
                                                                    "Completed" => "bg-success",
                                                                    "Rejected" => "bg-secondary",
                                                                    _ => "bg-secondary"
                                                                };
                                                            }
                                                            <span class="badge @badgeClass rounded-pill">@item.Status</span>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-5">
                                        <i class="fa-solid fa-clipboard-list text-muted fs-1 mb-3"></i>
                                        <p class="text-muted">No applications yet</p>
                                        <a href="@Url.Action("GoldenVisa", "Services")" class="btn btn-primary btn-sm">Start Your First Application</a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Right: Action Center -->
                    <div class="col-lg-4">
                        <div class="card dash-card h-100">
                            <div class="card-header bg-white border-bottom p-4">
                                <h6 class="fw-bold mb-0">Quick Actions</h6>
                            </div>
                            <div class="card-body d-flex flex-column gap-3 p-4">
                                
                                <a href="@Url.Action("GoldenVisa", "Services")" class="btn btn-outline-primary w-100 text-start py-3 px-4 d-flex align-items-center rounded-3">
                                    <i class="fa-solid fa-passport fs-4 me-3"></i>
                                    <div>
                                        <h6 class="mb-0 fw-bold">Golden Visa</h6>
                                        <small class="text-muted">10-year residency visa</small>
                                    </div>
                                    <i class="fa-solid fa-chevron-right ms-auto"></i>
                                </a>

                                <a href="@Url.Action("DrivingLicense", "Services")" class="btn btn-outline-dark w-100 text-start py-3 px-4 d-flex align-items-center rounded-3">
                                    <i class="fa-solid fa-car fs-4 me-3"></i>
                                    <div>
                                        <h6 class="mb-0 fw-bold">Driving License</h6>
                                        <small class="text-muted">Renew your license</small>
                                    </div>
                                    <i class="fa-solid fa-chevron-right ms-auto"></i>
                                </a>
                                
                                <div class="mt-auto pt-3 border-top text-center">
                                    <small class="text-muted d-block mb-2">Need immediate assistance?</small>
                                    <a href="https://wa.me/971543149939" target="_blank" class="btn btn-success w-100">
                                        <i class="fa-brands fa-whatsapp me-2"></i> Contact Support
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const sidebar = document.getElementById('sidebar');
            const wrapper = document.getElementById('wrapper');
            
            const desktopToggleBtn = document.getElementById('sidebarCollapseDesktop');
            desktopToggleBtn.addEventListener('click', function() {
                sidebar.classList.toggle('collapsed');
                wrapper.classList.toggle('sidebar-collapsed');
                
                const icon = desktopToggleBtn.querySelector('i');
                if (sidebar.classList.contains('collapsed')) {
                    icon.classList.remove('fa-bars-staggered');
                    icon.classList.add('fa-bars');
                } else {
                    icon.classList.remove('fa-bars');
                    icon.classList.add('fa-bars-staggered');
                }
            });

            const overlay = document.getElementById('sidebarOverlay');
            const mobileToggleBtn = document.getElementById('sidebarCollapseMobile');

            function toggleMobileSidebar() {
                sidebar.classList.toggle('active');
                overlay.classList.toggle('active');
            }

            mobileToggleBtn.addEventListener('click', toggleMobileSidebar);
            overlay.addEventListener('click', toggleMobileSidebar);
        });
    </script>
</body>
</html>