@model LoginViewModel
@{
    ViewData["Title"] = "Login - Flyzone";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/flyzone-auth.css" asp-append-version="true" />
</head>
<body>
    
    <a href="@Url.Action("Index", "Home")" class="back-to-home">
        <i class="fa-solid fa-arrow-left me-2"></i> Back to Home
    </a>

    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-header">
                <a href="@Url.Action("Index", "Home")" class="brand-logo">
                    <i class="fa-solid fa-feather-pointed me-2" style="color: var(--fz-green);"></i>FLY<span>ZONE</span>
                </a>
                <p class="text-muted small mb-0">Sign in to your account</p>
            </div>

            <div class="auth-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" id="emailInput" placeholder="name@example.com">
                        <label for="emailInput"><i class="fa-regular fa-envelope me-2 text-muted"></i>Email address</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Password" class="form-control" id="passwordInput" placeholder="Password">
                        <label for="passwordInput"><i class="fa-solid fa-lock me-2 text-muted"></i>Password</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 auth-links">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" id="rememberMeCheck">
                            <label class="form-check-label text-muted small" for="rememberMeCheck">
                                Remember me
                            </label>
                        </div>
                        <a href="#">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-auth-primary w-100 mb-3">
                        <i class="fa-solid fa-right-to-bracket me-2"></i> Login
                    </button>

                    <div class="text-center auth-links mt-3">
                        <span class="text-muted small">Don't have an account?</span> 
                        <a href="@Url.Action("Register", "Account")">Register here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>